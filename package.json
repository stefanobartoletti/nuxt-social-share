{
  "name": "@stefanobartoletti/nuxt-social-share",
  "type": "module",
  "version": "3.0.3",
  "packageManager": "pnpm@10.34.1",
  "description": "Simple Social Sharing for Nuxt",
  "author": "Stefano Bartoletti (https://github.com/stefanobartoletti/)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stefanobartoletti/nuxt-social-share.git"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "social-sharing",
    "social-share"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "docs:dev": "nuxi dev docs",
    "docs:build": "nuxi build docs",
    "docs:generate": "nuxt prepare && nuxi generate docs",
    "docs:preview": "nuxi preview docs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "release": "pnpm lint && pnpm test && pnpm prepack && bumpp -r --all",
    "commitlint": "commitlint --edit",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.7",
    "defu": "^6.1.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@nuxt/devtools": "3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.7",
    "@nuxt/test-utils": "^3.23.0",
    "@stefanobartoletti/eslint-config": "^5.0.2",
    "@types/node": "^24.12.4",
    "bumpp": "^11.1.0",
    "changelogen": "^0.6.2",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "nuxt": "^4.4.7",
    "typescript": "~5.9.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.3"
  }
}
